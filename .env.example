# Voice Bridge Configuration

# Matrix Credentials
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@yourbot:matrix.org
MATRIX_ACCESS_TOKEN=your_access_token_here

# OpenClaw Integration
OPENCLAW_URL=http://localhost:8000
OPENCLAW_API_KEY=optional_api_key

# Whisper Settings
WHISPER_MODEL=base  # tiny, base, small, medium, large
WHISPER_DEVICE=auto  # cpu, cuda, auto

# TTS Settings
TTS_ENGINE=kokoro  # kokoro, piper, pyttsx3
KOKORO_VOICE=af_bella  # af_bella, af_sarah, am_adam, etc
PIPER_VOICE=en_US-lessac-medium

# Session Settings
SESSION_TIMEOUT=3600  # Seconds before session expires

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
